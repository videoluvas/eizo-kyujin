// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Job {
  id        Int       @id @default(autoincrement())
  url       String    @unique @db.Text
  title     String    @db.Text
  company   String    @db.Text
  jt        String?   @db.Text
  st        String?   @db.Text
  area      String?   @db.Text
  snippet   String?   @db.Text
  update    DateTime?
  tracking  String?   @db.Text
  category  String[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("jobs")
}

model Category {
  nameEn String @id @map("name_en") @db.Text
  group  String @db.Text
  name   String @unique @db.Text
  keywords String @default("") @db.Text
  order    Int    @default(0)
  icon     String @default("")  

  @@map("categories")
}

model SearchKeyword {
  id           Int      @id @default(autoincrement())
  keyword      String   @unique @db.Text
  total        Int?
  currentStart Int      @default(1) @map("current_start")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("search_keywords")
}

model WorkStyle {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("work_styles")
}

model Area {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.Text
  order    Int    @default(0)  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  imgUrl    String   @default("")

  @@map("areas")
}

model SeoSetting {
  id            Int    @id @default(autoincrement())
  page          String @unique @db.Text
  title         String @db.Text
  description   String @db.Text
  ogTitle       String @default("") @db.Text
  ogDescription String @default("") @db.Text
  ogImage       String @default("") @db.Text
  @@map("seo_settings")
}