// Post関連のスキーマ

model Post {
  id              Int       @id @default(autoincrement())
  slug            String    @unique @db.Text

  // 基本情報
  title           String    @default("") @db.Text
  metaTitle       String    @default("") @db.Text
  metaDescription String    @default("") @db.Text
  thumbnail       String    @default("") @db.Text
  ogImage         String    @default("") @db.Text
  category        String    @default("") @db.Text
  relatedCategory String    @default("") @db.Text
  author          String    @default("映像求人PRO編集部") @db.Text
  readingTime     Int       @default(0)
  tags            String[]

  // リード文
  lead            String    @default("") @db.Text

  // H2_1: 仕事とは？市場動向
  h2_1_title      String    @default("") @db.Text
  h3_1_1          String    @default("") @db.Text
  p_1_1           String    @default("") @db.Text
  h3_1_2          String    @default("") @db.Text
  p_1_2           String    @default("") @db.Text
  h3_1_3          String    @default("") @db.Text
  p_1_3           String    @default("") @db.Text

  // H2_3: 求められるスキル
  h2_3_title      String    @default("") @db.Text
  h3_3_1          String    @default("") @db.Text
  p_3_1           String    @default("") @db.Text
  h3_3_2          String    @default("") @db.Text
  p_3_2           String    @default("") @db.Text
  h3_3_3          String    @default("") @db.Text
  p_3_3           String    @default("") @db.Text

  // H2_4: 年収・給与相場
  h2_4_title      String    @default("") @db.Text
  p_4_1           String    @default("") @db.Text
  p_4_2           String    @default("") @db.Text

  // H2_5: 失敗しないポイント
  h2_5_title      String    @default("") @db.Text
  h3_5_1          String    @default("") @db.Text
  p_5_1           String    @default("") @db.Text
  h3_5_2          String    @default("") @db.Text
  p_5_2           String    @default("") @db.Text
  h3_5_3          String    @default("") @db.Text
  p_5_3           String    @default("") @db.Text

  // 公開設定
  published       Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("posts")
}
