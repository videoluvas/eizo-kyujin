model Post {
  id              Int       @id @default(autoincrement())
  slug            String    @unique
  title           String    @default("")
  thumbnail       String    @default("")
  category        String    @default("")
  published       Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  author          String    @default("映像求人PRO編集部")
  h2_1_title      String    @default("")
  h2_3_title      String    @default("")
  h2_4_title      String    @default("")
  h2_5_title      String    @default("")
  h3_1_1          String    @default("")
  h3_1_2          String    @default("")
  h3_1_3          String    @default("")
  h3_3_1          String    @default("")
  h3_3_2          String    @default("")
  h3_3_3          String    @default("")
  h3_5_1          String    @default("")
  h3_5_2          String    @default("")
  h3_5_3          String    @default("")
  lead            String    @default("")
  metaDescription String    @default("")
  metaTitle       String    @default("")
  ogImage         String    @default("")
  p_1_1           String    @default("")
  p_1_2           String    @default("")
  p_1_3           String    @default("")
  p_3_1           String    @default("")
  p_3_2           String    @default("")
  p_3_3           String    @default("")
  p_4_1           String    @default("")
  p_4_2           String    @default("")
  p_5_1           String    @default("")
  p_5_2           String    @default("")
  p_5_3           String    @default("")
  readingTime     Int       @default(0)
  relatedCategory String    @default("")
  tags            String[]

  @@map("posts")
}
