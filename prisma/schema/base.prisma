generator client {
  provider = "prisma-client"
  output   = "../../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Job {
  id          Int       @id @default(autoincrement())
  url         String
  title       String
  company     String
  jt          String?
  st          String?
  area        String?
  snippet     String?
  update      DateTime?
  tracking    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  category    String[]
  firstSeenAt DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime  @default(now()) @map("last_seen_at")
  sourceKeyword String?  @map("source_keyword")

  @@unique([title, company])
  @@map("jobs")
}

model ArchivedJob {
  id            Int       @id @default(autoincrement())
  originalId    Int       @map("original_id")
  url           String
  title         String
  company       String
  jt            String?
  st            String?
  area          String?
  snippet       String?
  update        DateTime?
  tracking      String?
  category      String[]
  sourceKeyword String?   @map("source_keyword")
  firstSeenAt   DateTime  @map("first_seen_at")
  lastSeenAt    DateTime  @map("last_seen_at")
  archivedAt    DateTime  @default(now()) @map("archived_at")
  archivedBy    String    @default("") @map("archived_by")
  @@map("archived_jobs")
}

model Category {
  nameEn   String @id @map("name_en")
  group    String
  name     String @unique
  keywords String @default("")
  order    Int    @default(0)
  icon     String @default("")
  relatedGroup String @default("") @map("related_group")  

  @@map("categories")
}

model SearchKeyword {
  id           Int      @id @default(autoincrement())
  keyword      String   @unique
  total        Int?
  currentStart Int      @default(1) @map("current_start")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  fetchCount  Int  @default(0)

  @@map("search_keywords")
}

model NgKeyword {
  id        Int      @id @default(autoincrement())
  keyword   String   @unique
  targets   String[] // ["title", "company", "snippet"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("ng_keywords")
}

model WorkStyle {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("work_styles")
}

model Area {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Int      @default(0)
  imgUrl    String   @default("")

  @@map("areas")
}

model SeoSetting {
  id            Int    @id @default(autoincrement())
  page          String @unique
  title         String
  description   String
  ogTitle       String @default("")
  ogDescription String @default("")
  ogImage       String @default("")

  @@map("seo_settings")
}
